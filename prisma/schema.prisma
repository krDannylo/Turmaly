generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum ClassroomType {
  PRIVATE
  PUBLIC
}

model Teacher {
  id              Int           @id @default(autoincrement())
  name            String
  email           String        @unique
  password        String
  expertiseAreas  Expertise[]   @relation("teacher_expertise")
  classrooms      Classroom[]
  posts           Post[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Expertise {
  id              Int           @id @default(autoincrement())
  name            String        @unique
  teachers        Teacher[]     @relation("teacher_expertise")

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Classroom {
  id              Int           @id @default(autoincrement())
  name            String        @unique
  type            ClassroomType
  teacherId       Int           //Chave Estrangeira, associa turma ao professor
  teacher         Teacher       @relation(fields: [teacherId], references: [id])
  students        Student[]
  lessons         Lesson[]
  posts           Post[]
  enrollmentCode  EnrollmentCode[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Lesson {
  id              Int           @id @default(autoincrement())
  startAt         DateTime
  endAt           DateTime
  classroomId     Int           //Chave estrangeira
  classroom       Classroom     @relation(fields: [classroomId], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Post {
  id              Int           @id @default(autoincrement())
  title           String        
  content         String?
  isPinned        Boolean       @default(false)
  teacher         Teacher       @relation(fields: [teacherId], references: [id])
  teacherId       Int
  classroom       Classroom     @relation(fields: [classroomId], references: [id])
  classroomId     Int

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model EnrollmentCode {
  id              Int           @id @default(autoincrement())
  code            String        @unique
  unique          Boolean       @default(false)
  used            Boolean       @default(false)
  expiresAt       DateTime      
  classroom       Classroom     @relation(fields: [classroomId], references: [id])
  classroomId     Int

  createdAt       DateTime      @default(now())
}

model Student {
  id              Int           @id @default(autoincrement())
  name            String
  email           String        @unique
  phone           String?       @unique
  password        String
  classroomId     Int?           //Chave estrangeira
  classroom       Classroom?     @relation(fields: [classroomId], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

