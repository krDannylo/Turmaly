generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum ClassroomType {
  PRIVATE
  PUBLIC
}

enum UserRole {
  TEACHER
  STUDENT
}

model User {
  id              Int           @id @default(autoincrement())
  name            String
  email           String        @unique
  phone           String?       @unique
  password        String
  role            UserRole

  teacher         Teacher?
  student         Student?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Teacher {
  id              Int           @id @default(autoincrement())
  userId          Int           @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  expertiseAreas  Expertise[]   @relation("teacher_expertise")
  classrooms      Classroom[]
  posts           Post[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Student {
  id              Int           @id @default(autoincrement())
  userId          Int           @unique
  user            User          @relation(fields: [userId], references: [id])

  classroomStudents ClassroomStudent[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Expertise {
  id              Int           @id @default(autoincrement())
  name            String        @unique
  teachers        Teacher[]     @relation("teacher_expertise")

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Classroom {
  id              Int           @id @default(autoincrement())
  name            String        @unique
  type            ClassroomType
  lessons         Lesson[]
  posts           Post[]
  enrollmentCode  EnrollmentCode[]
  classroomStudents ClassroomStudent[]

  teacherId       Int           //Chave Estrangeira, associa turma ao professor
  teacher         Teacher       @relation(fields: [teacherId], references: [id])

  @@index([teacherId])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Lesson {
  id              Int           @id @default(autoincrement())
  startAt         DateTime
  endAt           DateTime

  classroomId     Int           //Chave estrangeira
  classroom       Classroom     @relation(fields: [classroomId], references: [id])

  @@index([classroomId])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Post {
  id              Int           @id @default(autoincrement())
  title           String        
  content         String?
  isPinned        Boolean       @default(false)
  priority        Boolean       @default(false)

  teacherId       Int
  teacher         Teacher       @relation(fields: [teacherId], references: [id])
  classroomId     Int
  classroom       Classroom     @relation(fields: [classroomId], references: [id])

  @@index([classroomId])
  @@index([teacherId])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model EnrollmentCode {
  id              Int           @id @default(autoincrement())
  code            String        @unique
  unique          Boolean       @default(false)
  used            Boolean       @default(false)
  expiresAt       DateTime      

  classroomId     Int
  classroom       Classroom     @relation(fields: [classroomId], references: [id])

  createdAt       DateTime      @default(now())
}

model ClassroomStudent {
  classroomId     Int
  studentId       Int

  classroom       Classroom     @relation(fields: [classroomId], references: [id])
  student         Student       @relation(fields: [studentId], references: [id])

  @@id([classroomId, studentId]) // impede duplicação
}

