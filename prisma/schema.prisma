generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Teacher {
  id             Int         @id @default(autoincrement())
  name           String
  email          String      @unique
  password       String
  expertiseAreas Expertise[] @relation("teacher_expertise")

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Expertise {
  id             Int        @id @default(autoincrement())
  name           String     @unique
  teachers       Teacher[]  @relation("teacher_expertise")

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

