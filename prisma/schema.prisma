generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Teacher {
  id             Int     @id @default(autoincrement())
  name           String
  email          String  @unique
  password       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

